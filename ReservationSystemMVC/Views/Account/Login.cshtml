@{
    ViewData["Title"] = "Login";
}

<div class="max-w-md mx-auto bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-4">Login</h1>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="mb-4 rounded-lg bg-red-50 text-red-700 px-4 py-2">@ViewBag.ErrorMessage</div>
    }

    <form asp-controller="Account" asp-action="Login" method="post" class="space-y-4">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" name="email" required class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input type="password" name="password" required class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500" />
        </div>

        <button type="submit" class="w-full px-6 py-2.5 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition shadow">
            Sign in
        </button>
    </form>

    <p class="text-sm text-gray-500 mt-4">
        Nu ai cont?
        <a asp-controller="Account" asp-action="Register" class="text-brand-600 hover:underline">Register</a>
    </p>
</div>
