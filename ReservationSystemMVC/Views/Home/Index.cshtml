@{
    ViewData["Title"] = "Acasă";
}

<!-- ===== HERO ===== -->
<section class="relative bg-gradient-to-br from-brand-600 to-brand-700 text-white rounded-2xl overflow-hidden mb-12">
    <div class="max-w-7xl mx-auto px-6 py-16 lg:py-24 flex flex-col lg:flex-row items-center gap-12">
        <div class="lg:w-3/5 space-y-6">
            <h1 class="text-4xl lg:text-5xl font-extrabold leading-tight">
                Rezervări rapide pentru hoteluri, apartamente și evenimente
            </h1>
            <p class="text-lg text-blue-100">
                Caută, compară și rezervă spații potrivite pentru nevoile tale în câteva minute.
            </p>
            <div class="flex gap-3">
                <a href="#search" class="px-6 py-3 bg-white text-brand-700 font-semibold rounded-lg shadow hover:bg-gray-100 transition">
                    Caută acum
                </a>
                <a href="#hotels" class="px-6 py-3 border-2 border-white/60 text-white font-semibold rounded-lg hover:bg-white/10 transition">
                    Vezi oferte
                </a>
            </div>
        </div>
        <div class="lg:w-2/5">
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 space-y-3">
                <h3 class="text-lg font-semibold">De ce noi?</h3>
                <ul class="space-y-2 text-blue-100">
                    <li>✔️ Disponibilitate actualizată</li>
                    <li>✔️ Confirmare rapidă</li>
                    <li>✔️ Plăți sigure</li>
                    <li>✔️ Suport dedicat</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- ===== SEARCH ===== -->
<section id="search" class="mb-12">
    <form method="get" asp-controller="Search" asp-action="Index"
          class="bg-white rounded-xl shadow-md p-6 grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tip</label>
            <select name="Category" required
                    class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500">
                <option value="">-- alege --</option>
                <option value="Hotel">Hotel</option>
                <option value="Apartment">Apartament</option>
                <option value="Event">Event</option>
            </select>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Data începerii</label>
            <input type="date" name="StartDate" required
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500" />
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Durată (zile)</label>
            <input type="number" name="Days" min="1" value="1" required
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500" />
        </div>
        <div>
            <button type="submit"
                    class="w-full px-6 py-2.5 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition shadow">
                🔍 Caută
            </button>
        </div>
    </form>
</section>

<!-- ===== HOTELS ===== -->
<section id="hotels" class="mb-16">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-800">🏨 Hoteluri populare</h2>
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Hotel"
           class="text-sm font-medium text-brand-600 hover:underline">Vezi toate →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- JW Marriott -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Hotel" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600" alt="JW Marriott Bucharest"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">JW Marriott Bucharest</h3>
                    <span class="text-sm font-bold text-yellow-600">⭐ 4.7</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 București, România</p>
                <p class="text-gray-400 text-xs mt-1">Camere spațioase, mic dejun inclus, spa de lux, în centrul Bucureștiului.</p>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-700 rounded-full">de la 190 €/noapte</span>
            </div>
        </a>
        <!-- Athenee Palace Hilton -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Hotel" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=600" alt="Athenee Palace Hilton"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">Athenee Palace Hilton</h3>
                    <span class="text-sm font-bold text-yellow-600">⭐ 4.6</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 București, România</p>
                <p class="text-gray-400 text-xs mt-1">Hotel istoric 5 stele, vizavi de Ateneul Român, elegantă clasică.</p>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-700 rounded-full">de la 210 €/noapte</span>
            </div>
        </a>
        <!-- Ritz Paris -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Hotel" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=600" alt="Ritz Paris"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">Ritz Paris</h3>
                    <span class="text-sm font-bold text-yellow-600">⭐ 4.9</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 Paris, Franța</p>
                <p class="text-gray-400 text-xs mt-1">Lux absolut pe Place Vendôme, hotelul legendar din 1898.</p>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-blue-100 text-blue-700 rounded-full">de la 950 €/noapte</span>
            </div>
        </a>
    </div>
</section>

<!-- ===== APARTMENTS ===== -->
<section id="apartments" class="mb-16">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-800">🏠 Apartamente recomandate</h2>
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Apartment"
           class="text-sm font-medium text-brand-600 hover:underline">Vezi toate →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Central Old Town -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Apartment" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=600" alt="Central Old Town Apartment"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">Central Old Town</h3>
                    <span class="text-sm font-bold text-yellow-600">⭐ 4.6</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 București, România</p>
                <p class="text-gray-400 text-xs mt-1">Apartament modern în Centrul Vechi, 55m², 2 camere, bucătărie echipată.</p>
                <div class="flex items-center gap-2 mt-2 text-xs text-gray-400">
                    <span>🛏 2 paturi</span> <span>🚿 1 baie</span> <span>👥 max 4</span>
                </div>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-green-100 text-green-700 rounded-full">de la 85 €/noapte</span>
            </div>
        </a>
        <!-- Herăstrău Park View -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Apartment" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=600" alt="Herăstrău Park View Apartment"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">Herăstrău Park View</h3>
                    <span class="text-sm font-bold text-yellow-600">⭐ 4.7</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 București, România</p>
                <p class="text-gray-400 text-xs mt-1">Apartament spațios cu vedere parc, 90m², 3 camere, parcare inclusă.</p>
                <div class="flex items-center gap-2 mt-2 text-xs text-gray-400">
                    <span>🛏 4 paturi</span> <span>🚿 2 băi</span> <span>👥 max 6</span>
                </div>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-green-100 text-green-700 rounded-full">de la 140 €/noapte</span>
            </div>
        </a>
    </div>
</section>

<!-- ===== EVENTS ===== -->
<section id="events" class="mb-16">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-800">🎉 Spații pentru evenimente</h2>
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Event"
           class="text-sm font-medium text-brand-600 hover:underline">Vezi toate →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- ROMEXPO -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Event" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600" alt="ROMEXPO"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">ROMEXPO Pavilion B1</h3>
                    <span class="px-2 py-0.5 text-xs font-semibold bg-amber-100 text-amber-700 rounded-full">Exhibition</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 București, România</p>
                <p class="text-gray-400 text-xs mt-1">Capacitate 2000 persoane, ideal expoziții și conferințe mari.</p>
                <div class="flex items-center gap-2 mt-2 text-xs text-gray-400">
                    <span>👥 2,000 locuri</span> <span>📅 15.09.2026</span>
                </div>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-amber-100 text-amber-700 rounded-full">de la 1200 €/zi</span>
            </div>
        </a>
        <!-- Sala Palatului -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Event" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1459749411175-04bf5292ceea?w=600" alt="Sala Palatului"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">Sala Palatului</h3>
                    <span class="px-2 py-0.5 text-xs font-semibold bg-amber-100 text-amber-700 rounded-full">Concert</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 București, România</p>
                <p class="text-gray-400 text-xs mt-1">Acustică excepțională, sala emblematică a capitalei.</p>
                <div class="flex items-center gap-2 mt-2 text-xs text-gray-400">
                    <span>👥 4,000 locuri</span> <span>📅 20.07.2026</span> <span>🔞 12+</span>
                </div>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-amber-100 text-amber-700 rounded-full">de la 2500 €/zi</span>
            </div>
        </a>
        <!-- Cluj Arena -->
        <a asp-controller="Search" asp-action="Index" asp-route-Category="Event" asp-route-Days="1"
           class="bg-white rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden group block">
            <img src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=600" alt="Cluj Arena"
                 class="w-full h-48 object-cover" />
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-lg text-gray-800 group-hover:text-brand-600 transition">Cluj Arena</h3>
                    <span class="px-2 py-0.5 text-xs font-semibold bg-amber-100 text-amber-700 rounded-full">Festival</span>
                </div>
                <p class="text-gray-500 text-sm mt-1">📍 Cluj-Napoca, România</p>
                <p class="text-gray-400 text-xs mt-1">25000 locuri, concerte și festivaluri de amploare (Untold).</p>
                <div class="flex items-center gap-2 mt-2 text-xs text-gray-400">
                    <span>👥 25,000 locuri</span> <span>📅 05.08.2026</span> <span>🔞 16+</span>
                </div>
                <span class="inline-block mt-3 px-3 py-1 text-xs font-semibold bg-amber-100 text-amber-700 rounded-full">de la 8000 €/zi</span>
            </div>
        </a>
    </div>
</section>

<!-- ===== MY RESERVATIONS ===== -->
<section id="reservations" class="mb-16">
    <div class="bg-white rounded-xl shadow-sm p-8 flex flex-col lg:flex-row items-center gap-8">
        <div class="lg:w-3/5 space-y-3">
            <h2 class="text-2xl font-bold text-gray-800">📋 Rezervările tale, într-un singur loc</h2>
            <p class="text-gray-500">Gestionează rezervările, plățile și istoricul fără efort.</p>
        </div>
        <div class="lg:w-2/5 bg-gray-50 border border-gray-200 rounded-lg p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-2">Exemplu</p>
            <p class="font-medium text-gray-800">Hotel Deluxe • 3 nopți</p>
            <p class="text-sm text-gray-500">Confirmat · 01–04 Mai</p>
        </div>
    </div>
</section>

<!-- ===== ADMIN ===== -->
<section id="admin" class="mb-16">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">⚙️ Admin</h2>
    <p class="text-gray-500 mb-5">Acces rapid la gestiunea resurselor, prețurilor și rezervărilor.</p>
    <div class="flex flex-wrap gap-3">
        <button type="button" class="px-5 py-2.5 border-2 border-brand-600 text-brand-600 font-medium rounded-lg hover:bg-brand-600 hover:text-white transition">Gestionează hoteluri</button>
        <button type="button" class="px-5 py-2.5 border-2 border-brand-600 text-brand-600 font-medium rounded-lg hover:bg-brand-600 hover:text-white transition">Gestionează apartamente</button>
        <button type="button" class="px-5 py-2.5 border-2 border-brand-600 text-brand-600 font-medium rounded-lg hover:bg-brand-600 hover:text-white transition">Gestionează evenimente</button>
    </div>
</section>

<!-- ===== AUTH ===== -->
<section id="auth" class="mb-16">
    <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-xl p-8 flex flex-col lg:flex-row items-center justify-between gap-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-800">🔐 Autentificare rapidă</h2>
            <p class="text-gray-500 mt-1">Creează un cont sau intră pentru a gestiona rezervările tale.</p>
        </div>
        <div class="flex gap-3">
            <button type="button" class="px-6 py-2.5 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition shadow">Login</button>
            <button type="button" class="px-6 py-2.5 border-2 border-gray-300 text-gray-700 font-semibold rounded-lg hover:border-gray-400 transition">Register</button>
        </div>
    </div>
</section>

<!-- ===== CONTACT ===== -->
<section id="contact" class="mb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-4">
            <h2 class="text-2xl font-bold text-gray-800">📞 Contact</h2>
            <p class="text-gray-500">Ai întrebări? Scrie-ne și îți răspundem rapid.</p>
            <p class="text-gray-700"><strong>Email:</strong> suport&#64;rezervari.ro</p>
            <p class="text-gray-700"><strong>Telefon:</strong> +40 700 000 000</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
            <h3 class="text-lg font-semibold text-gray-800">Trimite un mesaj</h3>
            <input type="text" placeholder="Nume" class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500" />
            <input type="email" placeholder="Email" class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500" />
            <textarea rows="3" placeholder="Mesaj" class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-brand-500 focus:border-brand-500"></textarea>
            <button type="button" class="px-6 py-2.5 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition shadow">Trimite</button>
        </div>
    </div>
</section>
