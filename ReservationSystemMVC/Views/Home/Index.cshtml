@{
    ViewData["Title"] = "Acasă";
}

<section class="py-5 bg-light border rounded-3 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold">Rezervări rapide pentru hoteluri, apartamente și evenimente</h1>
                <p class="lead text-muted">Caută, compară și rezervă spații potrivite pentru nevoile tale în câteva minute.</p>
                <div class="d-flex gap-2">
                    <a class="btn btn-primary btn-lg" href="#search">Caută acum</a>
                    <a class="btn btn-outline-secondary btn-lg" href="#hotels">Vezi oferte</a>
                </div>
            </div>
            <div class="col-lg-5 mt-4 mt-lg-0">
                <div class="p-4 bg-white border rounded-3 shadow-sm">
                    <h5 class="mb-3">De ce noi?</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">✔️ Disponibilitate actualizată</li>
                        <li class="mb-2">✔️ Confirmare rapidă</li>
                        <li class="mb-2">✔️ Plăți sigure</li>
                        <li>✔️ Suport dedicat</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="search" class="py-4">
    <div class="container">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Tip cazare</label>
                <select class="form-select">
                    <option>Hotel</option>
                    <option>Apartament</option>
                    <option>Event</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Data începerii</label>
                <input type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Durată (zile)</label>
                <input type="number" class="form-control" min="1" value="1" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100">Caută</button>
            </div>
        </div>
    </div>
</section>

<section id="hotels" class="py-5 bg-white">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h3 mb-0">Hoteluri populare</h2>
            <a class="link-primary" asp-controller="Resources" asp-action="Index">Vezi toate</a>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Hotel Deluxe</h5>
                        <p class="card-text text-muted">Camere spațioase, mic dejun inclus, aproape de centru.</p>
                        <span class="badge bg-primary">de la 100 €/noapte</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Hotel Urban</h5>
                        <p class="card-text text-muted">Design modern, acces rapid la transport.</p>
                        <span class="badge bg-primary">de la 85 €/noapte</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Hotel Boutique</h5>
                        <p class="card-text text-muted">Atmosferă premium și servicii personalizate.</p>
                        <span class="badge bg-primary">de la 120 €/noapte</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="apartments" class="py-5 bg-light">
    <div class="container">
        <h2 class="h3 mb-3">Apartamente recomandate</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Apartment Center</h5>
                        <p class="card-text text-muted">Perfect pentru familii, aproape de atracții.</p>
                        <span class="badge bg-success">de la 80 €/noapte</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Apartment Green</h5>
                        <p class="card-text text-muted">Spațiu generos, zonă liniștită.</p>
                        <span class="badge bg-success">de la 70 €/noapte</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="events" class="py-5 bg-white">
    <div class="container">
        <h2 class="h3 mb-3">Spații pentru evenimente</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Event Hall Premium</h5>
                        <p class="card-text text-muted">Capacitate mare, ideal pentru conferințe.</p>
                        <span class="badge bg-warning text-dark">de la 200 €/zi</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Event Loft</h5>
                        <p class="card-text text-muted">Spațiu versatil pentru evenimente corporate.</p>
                        <span class="badge bg-warning text-dark">de la 160 €/zi</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Garden Venue</h5>
                        <p class="card-text text-muted">Evenimente în aer liber, atmosferă relaxată.</p>
                        <span class="badge bg-warning text-dark">de la 140 €/zi</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="reservations" class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h2 class="h3">Rezervările tale, într-un singur loc</h2>
                <p class="text-muted">Gestionează rezervările, plățile și istoricul fără efort.</p>
            </div>
            <div class="col-lg-5">
                <div class="p-4 bg-white border rounded-3">
                    <h6 class="text-uppercase text-muted">Tip</h6>
                    <p class="mb-1">Hotel Deluxe • 3 nopți</p>
                    <p class="text-muted mb-0">Confirmat · 01-04 Mai</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="admin" class="py-5 bg-white">
    <div class="container">
        <h2 class="h3 mb-3">Admin</h2>
        <p class="text-muted">Acces rapid la gestiunea resurselor, prețurilor și rezervărilor.</p>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" type="button">Gestionează hoteluri</button>
            <button class="btn btn-outline-primary" type="button">Gestionează apartamente</button>
            <button class="btn btn-outline-primary" type="button">Gestionează evenimente</button>
        </div>
    </div>
</section>

<section id="auth" class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2 class="h3">Autentificare rapidă</h2>
                <p class="text-muted">Creează un cont sau intră pentru a gestiona rezervările tale.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <button class="btn btn-primary me-2" type="button">Login</button>
                <button class="btn btn-outline-secondary" type="button">Register</button>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="py-5 bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <h2 class="h3">Contact</h2>
                <p class="text-muted">Ai întrebări? Scrie-ne și îți răspundem rapid.</p>
                <p class="mb-1"><strong>Email:</strong> suport@rezervari.ro</p>
                <p class="mb-0"><strong>Telefon:</strong> +40 700 000 000</p>
            </div>
            <div class="col-md-6">
                <div class="p-4 border rounded-3 bg-light">
                    <h5 class="mb-3">Trimite un mesaj</h5>
                    <input class="form-control mb-2" placeholder="Nume" />
                    <input class="form-control mb-2" placeholder="Email" />
                    <textarea class="form-control mb-3" rows="3" placeholder="Mesaj"></textarea>
                    <button class="btn btn-primary" type="button">Trimite</button>
                </div>
            </div>
        </div>
    </div>
</section>
