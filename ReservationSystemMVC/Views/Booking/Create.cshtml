@model ReservationSystemMVC.Models.BookingCreateViewModel

@{
    ViewData["Title"] = "Crează Rezervare";
}

<div class="container mt-5">
    <h2>Efectuați o Rezervare</h2>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    <form method="post" asp-controller="Booking" asp-action="Create">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ResourceId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        @if (!string.IsNullOrWhiteSpace(Model.ResourceName))
        {
            <div class="alert alert-info">Rezervi: <strong>@Model.ResourceName</strong></div>
        }

        <div class="mb-3">
            <label asp-for="FullName" class="form-label"></label>
            <input asp-for="FullName" class="form-control" required />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>
        
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" type="email" class="form-control" required />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PhoneNumber" class="form-label"></label>
            <input asp-for="PhoneNumber" class="form-control" required />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" type="date" class="form-control" id="startDate" min="@Model.MinDate" required />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" type="date" class="form-control" id="endDate" min="@Model.MinDate" required />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="GuestsCount" class="form-label"></label>
            <input asp-for="GuestsCount" type="number" min="1" class="form-control" required />
            <span asp-validation-for="GuestsCount" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SpecialRequests" class="form-label"></label>
            <textarea asp-for="SpecialRequests" class="form-control" rows="3"></textarea>
            <span asp-validation-for="SpecialRequests" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Preț total estimat</label>
            <input type="text" class="form-control" id="totalPriceText" value="@Model.TotalPrice €" readonly />
            <input type="hidden" asp-for="TotalPrice" id="totalPrice" />
            <small id="availabilityText" class="form-text text-muted"></small>
        </div>

        <div class="mb-4">
            <h5 class="mb-3">Alegeți metoda de plată:</h5>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" asp-for="PaymentProvider" value="Stripe" id="payStripe" checked>
                <label class="form-check-label font-bold" for="payStripe">
                    💳 Card (prin Stripe)
                </label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" asp-for="PaymentProvider" value="PayPal" id="payPayPal">
                <label class="form-check-label font-bold text-blue-600" for="payPayPal">
                    P <span class="text-blue-800">PayPal</span>
                </label>
            </div>
            <span asp-validation-for="PaymentProvider" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Confirma Rezervarea</button> <button type="button" class="btn btn-warning ml-2" onclick="saveDraft()">Salveaza ca Draft (Memento/Command)</button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Anulează</a>
    </form><script>
function saveDraft() {
    const form = document.querySelector("form");
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    data.GuestsCount = parseInt(data.GuestsCount) || 1;
    data.TotalPrice = parseFloat(data.TotalPrice) || 0;
    // Remove antiforgery token - not needed for this endpoint
    delete data['__RequestVerificationToken'];

    fetch("/Draft/SaveDraft", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
    })
    .then(res => {
        if (!res.ok) throw new Error("Server error: " + res.status);
        return res.json();
    })
    .then(res => {
        if (res.success) {
            const btn = document.querySelector('[onclick="saveDraft()"]');
            if (btn) {
                btn.textContent = "✓ Draft Salvat!";
                btn.classList.replace("btn-warning", "btn-success");
                setTimeout(() => {
                    btn.textContent = "Salveaza ca Draft (Memento/Command)";
                    btn.classList.replace("btn-success", "btn-warning");
                }, 3000);
            }
        }
    })
    .catch(err => {
        alert("Eroare la salvarea draft-ului: " + err.message);
    });
}
</script>

