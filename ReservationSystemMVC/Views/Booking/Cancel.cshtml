@model ReservationSystemMVC.Core.Domain.Entities.Booking?

@{
    ViewData["Title"] = "Plată anulată";
}

<div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-red-200 p-6">
    <h2 class="text-2xl font-bold text-red-700 mb-3">❌ Plata a fost anulată</h2>
    <p class="text-gray-700 mb-4">Rezervarea a fost marcată ca <strong>Cancelled</strong>. Poți reîncerca oricând.</p>

    @if (Model is not null)
    {
        <p class="text-gray-700 mb-2"><strong>ID rezervare:</strong> @Model.Id</p>
        <p class="text-gray-700 mb-4"><strong>Perioadă:</strong> @Model.StartDate:dd.MM.yyyy - @Model.EndDate:dd.MM.yyyy</p>
    }

    <div class="flex gap-3">
        <a asp-controller="Booking" asp-action="MyBookings" class="btn btn-primary">Vezi rezervările mele</a>
        <a asp-controller="Search" asp-action="Index" class="btn btn-secondary">Caută din nou</a>
    </div>
</div>
