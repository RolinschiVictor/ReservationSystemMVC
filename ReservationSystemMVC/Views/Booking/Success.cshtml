@model ReservationSystemMVC.Core.Domain.Entities.Booking?

@{
    ViewData["Title"] = "Plată reușită";
}

<div class="max-w-2xl mx-auto bg-white rounded-xl shadow-sm border border-green-200 p-6">
    <h2 class="text-2xl font-bold text-green-700 mb-3">✅ Plata a fost procesată cu succes</h2>

    @if (Model is not null)
    {
        <p class="text-gray-700 mb-2"><strong>ID rezervare:</strong> @Model.Id</p>
        <p class="text-gray-700 mb-2"><strong>Perioadă:</strong> @Model.StartDate:dd.MM.yyyy - @Model.EndDate:dd.MM.yyyy</p>
        <p class="text-gray-700 mb-2"><strong>Total:</strong> @Model.TotalPrice €</p>
        <p class="text-gray-700 mb-4"><strong>Status:</strong> @Model.Status</p>
    }

    <div class="flex gap-3">
        <a asp-controller="Booking" asp-action="MyBookings" class="btn btn-primary">Vezi rezervările mele</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Înapoi la Home</a>
    </div>
</div>
